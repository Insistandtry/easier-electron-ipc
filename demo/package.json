{
  "name": "easier-electron-ipc-demo",
  "version": "1.0.0",
  "description": "Demo for easier-electron-ipc library",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "npx electron dist/main/index.js",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "npx tsc -p tsconfig.json",
    "build:preload": "npx webpack --config webpack.preload.config.js",
    "build:renderer": "npx webpack --config webpack.config.js",
    "dev": "npm run build && npm start"
  },
  "dependencies": {
    "easier-electron-ipc": "file:../",
    "electron": "^41.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "css-loader": "^6.9.1",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.7",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
