{
  "name": "easier-electron-ipc",
  "version": "1.0.1",
  "description": "Make electron-ipc communication easier.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "clean": "rimraf dist",
    "dev": "npm run clean && npm run build:watch",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "juno <panwithyu@outlook.com>",
  "license": "MIT",
  "dependencies": {
    "@types/electron": "1.6.12",
    "events": "^3.3.0"
  },
  "peerDependencies": {
    "electron": "*"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "rollup": "^4.6.1",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "keywords": [
    "electron",
    "ipc",
    "typescript",
    "communication"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Insistandtry/easier-electron-ipc.git"
  },
  "homepage": "https://github.com/Insistandtry/easier-electron-ipc.git#readme"
}
